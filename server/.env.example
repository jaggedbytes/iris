# Keep this file local. Never expose this value to the browser.
OPENAI_API_KEY=

# A stable, privacy-preserving identifier set by this trusted server. For this
# unauthenticated local prototype, use a non-identifying local value. Replace it
# with a hashed authenticated user ID before deployment.
IRIS_SAFETY_IDENTIFIER=iris-local-prototype

# The Vite development server origin.
FRONTEND_ORIGIN=http://localhost:5173
# Public legal links used by the trusted-contact SMS opt-in form. These defaults
# are real hosted Iris legal pages; override only with your own public HTTPS URLs.
IRIS_PRIVACY_URL=https://jaggedbytes.github.io/iris-legal/privacy/
IRIS_TERMS_URL=https://jaggedbytes.github.io/iris-legal/terms/
IRIS_SMS_DISCLOSURE_VERSION=2026-07-18
PORT=3001

# Local durable foundation storage. This file is ignored by Git. On Railway,
# attach a volume at /app/data and set this to /app/data/iris.sqlite.
IRIS_DATABASE_PATH=./data/iris.sqlite
IRIS_DEMO_PERSON_ID=person-demo

# Optional E.164 destination for the seeded demo person. Left blank the demo
# person has no callable number, so the dashboard cannot place a real call.
# Set this to a number you are authorized to call before testing outbound calls.
IRIS_DEMO_PHONE_E164=

# Required to access the local operator dashboard. Use a long random value.
IRIS_ADMIN_TOKEN=replace-with-a-long-local-secret

# Outbound Twilio phone transport. The public URL must be HTTPS so Twilio can
# POST TwiML and establish its secure Media Stream WebSocket.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
IRIS_PUBLIC_BASE_URL=https://your-public-tunnel.example

# Optional grace period after Iris uses end_call. This only bounds a missing
# farewell-completion event; it is not an idle-call timeout. Default: 8000 ms.
# Valid values are whole milliseconds from 1000 through 30000.
IRIS_FAREWELL_CLOSE_TIMEOUT_MS=8000

# Set to true only while diagnosing a live call. Logs Realtime event names,
# error metadata, and audio byte counts—never audio payloads or transcripts.
IRIS_REALTIME_DEBUG=false
