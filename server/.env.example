# Keep this file local. Never expose this value to the browser.
OPENAI_API_KEY=

# A stable, privacy-preserving identifier set by this trusted server. For this
# unauthenticated local prototype, use a non-identifying local value. Replace it
# with a hashed authenticated user ID before deployment.
IRIS_SAFETY_IDENTIFIER=iris-local-prototype

# The Vite development server origin.
FRONTEND_ORIGIN=http://localhost:5173
PORT=3001
